{
  "name": "voxai-voice-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node server/api.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "4.3.4",
    "busboy": "^1.6.0",
    "concurrently": "^9.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "4.5.14"
  }
}
